// Esquema de Prisma — Green Sol
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               String         @id @default(cuid())
  correo           String         @unique
  hashContrasena   String?
  pinHash          String?
  otpCorreoActivo  Boolean        @default(false)
  correoVerificado Boolean        @default(false)
  rol              Rol            @default(usuario)
  nombre           String?
  apellido         String?
  nombreUsuario    String?        @unique
  fotoUrl          String?
  pais             String?
  monedaPreferida  String?
  onboardingCerrado Int           @default(0)
  ingresos          Int           @default(0)
  creadoEn         DateTime       @default(now())
  sesiones         Sesion[]
  codigosOtp       CodigoOtp[]
  organizadas      Recolecta[]    @relation("organizadas")
  participaciones  Participante[]
  notificaciones   Notificacion[]
  metodosPago      MetodoPago[]
  valoracionesDadas     Valoracion[] @relation("dadas")
  valoracionesRecibidas Valoracion[] @relation("recibidas")
}

model Sesion {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiraEn  DateTime
  creadaEn  DateTime @default(now())
}

model CodigoOtp {
  id         String       @id @default(cuid())
  usuarioId  String
  usuario    Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  hashCodigo String
  proposito  OtpProposito
  expiraEn   DateTime
  usado      Boolean      @default(false)
  creadoEn   DateTime     @default(now())
}

model TasaCache {
  id          String   @id @default(cuid())
  fuente      String   @unique
  datos       Json
  actualizado DateTime @default(now())
}

model Recolecta {
  id            String          @id @default(cuid())
  tipo          TipoRecolecta
  nombre        String
  descripcion   String?
  visibilidad   Visibilidad     @default(privado)
  metodo        MetodoRecolecta @default(tradicional)
  moneda        String          @default("USD")
  montoAporte   Float?
  meta          Float?
  frecuencia    String?
  frecuenciaDias Int?
  cupoMiembros  Int?
  estado        EstadoRecolecta @default(abierta)
  organizadorId String
  organizador   Usuario         @relation("organizadas", fields: [organizadorId], references: [id])
  creadaEn      DateTime        @default(now())
  participantes Participante[]
  turnos        Turno[]
  aportes       Aporte[]
  valoraciones  Valoracion[]
  datosPago     DatosPagoRecolecta?
}

model DatosPagoRecolecta {
  id           String    @id @default(cuid())
  recolectaId  String    @unique
  recolecta    Recolecta @relation(fields: [recolectaId], references: [id], onDelete: Cascade)
  tipo         String // transferencia | pago_movil | wallet
  banco        String? // código del banco (transferencia / pago_movil)
  tipoCuenta   String? // corriente | ahorro
  numeroCuenta String?
  titular      String?
  cedula       String?
  telefono     String?
  wallet       String? // dirección (cripto)
}

model Participante {
  id          String    @id @default(cuid())
  recolectaId String
  recolecta   Recolecta @relation(fields: [recolectaId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  unidoEn     DateTime  @default(now())
  turno       Turno?
  aportes     Aporte[]

  @@unique([recolectaId, usuarioId])
}

model Turno {
  id             String       @id @default(cuid())
  recolectaId    String
  recolecta      Recolecta    @relation(fields: [recolectaId], references: [id], onDelete: Cascade)
  participanteId String       @unique
  participante   Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  posicion       Int
  cobrado        Boolean      @default(false)
}

model Aporte {
  id             String       @id @default(cuid())
  recolectaId    String
  recolecta      Recolecta    @relation(fields: [recolectaId], references: [id], onDelete: Cascade)
  participanteId String
  participante   Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  monto          Float
  referencia     String?
  comprobanteUrl String?
  estado         EstadoAporte @default(reportado)
  creadoEn       DateTime     @default(now())
}

model Notificacion {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo      String
  titulo    String
  cuerpo    String?
  enlace    String?
  leida     Boolean  @default(false)
  creadaEn  DateTime @default(now())
}

model MetodoPago {
  id           String   @id @default(cuid())
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria    String // fiat | cripto
  moneda       String // VES | USD | ... | USDC | SOL
  metodo       String // transferencia | pago_movil | efectivo | zelle | zinli | walytech | banco | usdc | sol
  alias        String?
  titular      String?
  cedula       String?
  banco        String?
  tipoCuenta   String?
  numeroCuenta String?
  telefono     String?
  email        String?
  wallet       String?
  detalle      String?
  principal    Boolean  @default(false)
  creadoEn     DateTime @default(now())
}

model Valoracion {
  id          String    @id @default(cuid())
  recolectaId String
  recolecta   Recolecta @relation(fields: [recolectaId], references: [id], onDelete: Cascade)
  deUsuarioId String
  deUsuario   Usuario   @relation("dadas", fields: [deUsuarioId], references: [id])
  aUsuarioId  String
  aUsuario    Usuario   @relation("recibidas", fields: [aUsuarioId], references: [id])
  voto        Int
  comentario  String?
  creadaEn    DateTime  @default(now())

  @@unique([recolectaId, deUsuarioId, aUsuarioId])
}

model ConfiguracionApp {
  clave String @id
  valor String
}

enum Rol {
  usuario
  admin_grupo
  super_admin
}

enum OtpProposito {
  verificacion
  reset_contrasena
}

enum TipoRecolecta {
  san
  vaca
}

enum Visibilidad {
  privado
  publico
}

enum MetodoRecolecta {
  tradicional
  cripto
}

enum EstadoRecolecta {
  abierta
  activa
  cerrada
}

enum EstadoAporte {
  reportado
  confirmado
  rechazado
}
