# Base de datos (dev local: Postgres en contenedor, puerto 5433)
DATABASE_URL="postgresql://greensol:greensol_dev@localhost:5433/greensol?schema=public"

# API privada de tasas (dolarvzla) — pedir key al responsable; solo USDT la requiere.
DOLARVZLA_API_KEY=""

# Secreto para proteger el endpoint de cron de tasas
CRON_SECRET=""

# SMTP para correos (OTP, reseteo). Si se deja vacío, en desarrollo los correos van a consola.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Green Sol <no-reply@tudominio.com>"

# Almacenamiento de archivos privados (KYC) — MinIO/S3. Si se deja vacío, cae a disco (.almacen/).
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="greensol-kyc"
S3_FORCE_PATH_STYLE="true"
